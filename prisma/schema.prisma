generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ──────────────────────────────────────────────
// ORGANIZATION & USERS
// ──────────────────────────────────────────────

model Organization {
  id              String           @id @default(cuid())
  name            String
  slug            String           @unique
  domain          String?
  isDemo          Boolean          @default(false)
  createdAt       DateTime         @default(now())
  users           User[]
  candidates      Candidate[]
  roles           Role[]
  cutlines        Cutline[]
  teamInvitations TeamInvitation[]
}

model User {
  id          String                @id @default(cuid())
  supabaseId  String?               @unique
  email       String                @unique
  name        String
  role        UserRole
  orgId       String
  org         Organization          @relation(fields: [orgId], references: [id])
  isActive         Boolean               @default(true)
  notes            Note[]
  invitations      AssessmentInvitation[]
  recordedOutcomes     OutcomeRecord[]
  teamInvitesSent      TeamInvitation[]       @relation("TeamInvitesSent")
  candidateAssignments CandidateAssignment[]
  createdAt            DateTime              @default(now())
}

enum UserRole {
  EXTERNAL_COLLABORATOR
  RECRUITER_COORDINATOR
  RECRUITING_MANAGER
  HIRING_MANAGER
  TA_LEADER
  ADMIN
}

model TeamInvitation {
  id         String       @id @default(cuid())
  orgId      String
  org        Organization @relation(fields: [orgId], references: [id])
  email      String
  name       String?
  role       UserRole
  invitedBy  String
  inviter    User         @relation("TeamInvitesSent", fields: [invitedBy], references: [id])
  token      String       @unique @default(uuid())
  status     InviteStatus @default(PENDING)
  expiresAt  DateTime
  createdAt  DateTime     @default(now())
  acceptedAt DateTime?

  @@index([email, orgId])
  @@index([token])
  @@index([orgId, status])
}

enum InviteStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

// ──────────────────────────────────────────────
// ROLES & CUTLINES
// ──────────────────────────────────────────────

model Role {
  id                 String                @id @default(cuid())
  name               String
  slug               String
  description        String?
  orgId              String
  org                Organization          @relation(fields: [orgId], references: [id])
  cutlines           Cutline[]
  compositeWeights   CompositeWeight[]
  candidates         Candidate[]
  invitations        AssessmentInvitation[]
  contentLibraries   ContentLibrary[]
  createdAt          DateTime              @default(now())
  // Role Builder fields
  isCustom           Boolean               @default(false)
  complexityLevel    ComplexityLevel?
  sourceType         RoleSourceType?
  jobDescriptionText String?
  onetCodes          String[]
  researchRationale  Json?
  confidenceScores   Json?
  hiringIntelligence Json?
  jdContext          Json?
  isGeneric          Boolean               @default(false)
  createdBy          String?
  versions           RoleVersion[]

  @@unique([slug, orgId])
}

model Cutline {
  id                  String       @id @default(cuid())
  roleId              String
  role                Role         @relation(fields: [roleId], references: [id])
  orgId               String
  org                 Organization @relation(fields: [orgId], references: [id])
  technicalAptitude   Int
  behavioralIntegrity Int
  learningVelocity    Int
  overallMinimum      Int?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  @@unique([roleId, orgId])
}

model CompositeWeight {
  id            String       @id @default(cuid())
  roleId        String
  role          Role         @relation(fields: [roleId], references: [id])
  constructId   String
  weight        Float
  version       Int          @default(1)
  source        WeightSource @default(RESEARCH_VALIDATED)
  effectiveFrom DateTime     @default(now())
  effectiveTo   DateTime?
  createdAt     DateTime     @default(now())

  @@unique([roleId, constructId, version])
}

enum WeightSource {
  RESEARCH_VALIDATED
  EMPIRICALLY_ADJUSTED
  CLIENT_CUSTOMIZED
}

model ContentLibrary {
  id                    String               @id @default(cuid())
  roleId                String
  role                  Role                 @relation(fields: [roleId], references: [id])
  version               Int                  @default(1)
  status                ContentLibraryStatus @default(GENERATING)
  content               Json                 // Full pre-generated content tree
  generationStartedAt   DateTime?
  generationCompletedAt DateTime?
  errorLog              Json?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt

  @@unique([roleId, version])
  @@index([roleId, status])
}

enum ContentLibraryStatus {
  GENERATING
  READY
  FAILED
  DEPRECATED
}

model RoleVersion {
  id            String   @id @default(cuid())
  roleId        String
  role          Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  versionNumber Int
  weights       Json
  cutlines      Json
  rationale     Json?
  changedBy     String
  changeNote    String?
  createdAt     DateTime @default(now())

  @@unique([roleId, versionNumber])
  @@index([roleId])
}

enum ComplexityLevel {
  LOW
  MEDIUM
  MEDIUM_HIGH
  HIGH
}

enum RoleSourceType {
  SYSTEM_DEFAULT
  JD_UPLOAD
  TEMPLATE_CLONE
  MANUAL_ENTRY
}

// ──────────────────────────────────────────────
// CANDIDATES & ASSESSMENTS
// ──────────────────────────────────────────────

model Candidate {
  id            String                @id @default(cuid())
  firstName     String
  lastName      String
  email         String
  phone         String?
  orgId         String
  org           Organization          @relation(fields: [orgId], references: [id])
  primaryRoleId String
  primaryRole   Role                  @relation(fields: [primaryRoleId], references: [id])
  status        CandidateStatus       @default(INCOMPLETE)
  assessment    Assessment?
  invitations   AssessmentInvitation[]
  notes         Note[]
  outcomes      OutcomeRecord[]
  assignments   CandidateAssignment[]
  resultsEmailSentAt DateTime?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  @@unique([email, orgId])
}

model CandidateAssignment {
  id          String    @id @default(cuid())
  candidateId String
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignedAt  DateTime  @default(now())

  @@unique([candidateId, userId])
  @@index([userId])
  @@index([candidateId])
}

enum CandidateStatus {
  INVITED
  INCOMPLETE
  SCORING
  RECOMMENDED
  REVIEW_REQUIRED
  DO_NOT_ADVANCE
}

model Assessment {
  id              String              @id @default(cuid())
  candidateId     String              @unique
  candidate       Candidate           @relation(fields: [candidateId], references: [id])
  startedAt       DateTime
  completedAt     DateTime?
  durationMinutes Int?
  subtestResults  SubtestResult[]
  compositeScores CompositeScore[]
  predictions     Prediction?
  redFlags        RedFlag[]
  aiInteractions  AIInteraction[]
  itemResponses   ItemResponse[]
  survey          PostAssessmentSurvey?
  // V2 conversational assessment relations
  messages          ConversationMessage[]
  assessmentState   AssessmentState?
  aiEvaluationRuns  AIEvaluationRun[]
  // Cost tracking
  scoringCostUsd    Float?
  scoringTokensIn   Int?
  scoringTokensOut  Int?
  createdAt       DateTime            @default(now())
}

// ──────────────────────────────────────────────
// CONSTRUCT SCORES
// ──────────────────────────────────────────────

model SubtestResult {
  id                String          @id @default(cuid())
  assessmentId      String
  assessment        Assessment      @relation(fields: [assessmentId], references: [id])
  construct         Construct
  layer             Layer
  rawScore          Float
  percentile        Int
  theta             Float?
  standardError     Float?
  responseTimeAvgMs Int?
  itemCount         Int
  aiFollowUpCount   Int             @default(0)
  calibrationScore  Float?
  calibrationBias   String?
  narrativeInsight  String?
  // V2 layered scoring fields
  layerARawScore          Float?
  layerBRawScore          Float?
  layerAWeight            Float?
  layerBWeight            Float?
  consistencyLevel        String?           // "HIGH" or "LOW"
  consistencyDownweighted Boolean           @default(false)
  ceilingType             CeilingTypeEnum?
  ceilingNarrative        String?
  scoringVersion          Int               @default(1)
  createdAt         DateTime        @default(now())

  @@unique([assessmentId, construct])
}

enum Layer {
  COGNITIVE_CORE
  TECHNICAL_APTITUDE
  BEHAVIORAL_INTEGRITY
}

enum Construct {
  FLUID_REASONING
  EXECUTIVE_CONTROL
  COGNITIVE_FLEXIBILITY
  METACOGNITIVE_CALIBRATION
  LEARNING_VELOCITY
  SYSTEMS_DIAGNOSTICS
  PATTERN_RECOGNITION
  QUANTITATIVE_REASONING
  SPATIAL_VISUALIZATION
  MECHANICAL_REASONING
  PROCEDURAL_RELIABILITY
  ETHICAL_JUDGMENT
}

model CompositeScore {
  id                  String     @id @default(cuid())
  assessmentId        String
  assessment          Assessment @relation(fields: [assessmentId], references: [id])
  roleSlug            String
  indexName            String
  score               Float
  percentile          Int
  passed              Boolean
  distanceFromCutline Float
  createdAt           DateTime   @default(now())

  @@unique([assessmentId, roleSlug])
}

// ──────────────────────────────────────────────
// AI-ADAPTIVE INTERACTIONS
// ──────────────────────────────────────────────

model AIInteraction {
  id                String     @id @default(cuid())
  assessmentId      String
  assessment        Assessment @relation(fields: [assessmentId], references: [id])
  construct         Construct
  sequenceOrder     Int
  triggerItemId     String?
  triggerResponse   String?
  aiPrompt          String
  candidateResponse String?
  responseTimeMs    Int?
  aiAnalysis        String?
  evidenceFor       Json?
  confidenceLevel   Float?
  createdAt         DateTime   @default(now())

  @@index([assessmentId, construct])
}

// ──────────────────────────────────────────────
// PREDICTIONS & FLAGS
// ──────────────────────────────────────────────

model Prediction {
  id                  String           @id @default(cuid())
  assessmentId        String           @unique
  assessment          Assessment       @relation(fields: [assessmentId], references: [id])
  rampTimeMonths      Float
  rampTimeLabel       String
  rampTimeFactors     Json
  supervisionLoad     SupervisionLevel
  supervisionScore    Int
  supervisionFactors  Json
  performanceCeiling  CeilingLevel
  ceilingFactors      Json
  ceilingCareerPath   Json
  attritionRisk       RiskLevel
  attritionFactors    Json
  attritionStrategies Json
  createdAt           DateTime         @default(now())
}

enum SupervisionLevel {
  LOW
  MEDIUM
  HIGH
}

enum CeilingLevel {
  HIGH
  MEDIUM
  LOW
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
}

model RedFlag {
  id           String       @id @default(cuid())
  assessmentId String
  assessment   Assessment   @relation(fields: [assessmentId], references: [id])
  severity     FlagSeverity
  category     String
  title        String
  description  String
  constructs   String[]
  createdAt    DateTime     @default(now())
}

enum FlagSeverity {
  CRITICAL
  WARNING
  INFO
}

// ──────────────────────────────────────────────
// NOTES & AUDIT
// ──────────────────────────────────────────────

model Note {
  id          String    @id @default(cuid())
  candidateId String
  candidate   Candidate @relation(fields: [candidateId], references: [id])
  authorId    String
  author      User      @relation(fields: [authorId], references: [id])
  content     String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model ActivityLog {
  id         String   @id @default(cuid())
  entityType String
  entityId   String
  action     String
  actorId    String?
  metadata   Json?
  createdAt  DateTime @default(now())
}

// ──────────────────────────────────────────────
// ASSESSMENT INVITATIONS
// ──────────────────────────────────────────────

model AssessmentInvitation {
  id            String           @id @default(cuid())
  candidateId   String
  candidate     Candidate        @relation(fields: [candidateId], references: [id])
  roleId        String
  role          Role             @relation(fields: [roleId], references: [id])
  invitedBy     String
  inviter       User             @relation(fields: [invitedBy], references: [id])
  invitedAt     DateTime         @default(now())
  expiresAt     DateTime
  status        InvitationStatus @default(PENDING)
  linkToken     String           @unique @default(cuid())
  emailSentAt   DateTime?
  linkOpenedAt  DateTime?
  reminderCount Int              @default(0)
  createdAt     DateTime         @default(now())

  @@index([linkToken])
  @@index([candidateId])
}

enum InvitationStatus {
  PENDING
  STARTED
  COMPLETED
  EXPIRED
}

// ──────────────────────────────────────────────
// ITEM RESPONSES & SURVEY
// ──────────────────────────────────────────────

model ItemResponse {
  id             String         @id @default(cuid())
  assessmentId   String
  assessment     Assessment     @relation(fields: [assessmentId], references: [id])
  itemId         String
  itemType       ItemType
  response       String
  responseTimeMs Int?
  confidence     Float?
  rawScore       Float?
  // V2 fields
  act            AssessmentAct?
  messageId      String?          // Links to ConversationMessage if from V2 chat
  createdAt      DateTime       @default(now())

  @@unique([assessmentId, itemId])
}

enum ItemType {
  MULTIPLE_CHOICE
  LIKERT
  OPEN_RESPONSE
  AI_PROBE
  TIMED_SEQUENCE
}

// ──────────────────────────────────────────────
// V2 CONVERSATIONAL ASSESSMENT ENUMS
// ──────────────────────────────────────────────

enum AssessmentAct {
  PHASE_0
  ACT_1
  ACT_2
  ACT_3
}

enum CeilingTypeEnum {
  HARD_CEILING
  SOFT_CEILING_TRAINABLE
  SOFT_CEILING_CONTEXT_DEPENDENT
  STRESS_INDUCED
  INSUFFICIENT_DATA
}

enum ConvoMessageRole {
  AGENT
  CANDIDATE
  SYSTEM
}

enum InteractionElementType {
  TEXT_RESPONSE
  MULTIPLE_CHOICE_INLINE
  NUMERIC_INPUT
  TIMED_CHALLENGE
  CONFIDENCE_RATING
  TRADEOFF_SELECTION
}

model PostAssessmentSurvey {
  id           String     @id @default(cuid())
  assessmentId String     @unique
  assessment   Assessment @relation(fields: [assessmentId], references: [id])
  difficulty   Int
  fairness     Int
  faceValidity Int
  openFeedback String?
  createdAt    DateTime   @default(now())
}

// ──────────────────────────────────────────────
// DATA REFINEMENT
// ──────────────────────────────────────────────

model OutcomeRecord {
  id          String        @id @default(cuid())
  candidateId String
  candidate   Candidate     @relation(fields: [candidateId], references: [id])
  metricType  OutcomeMetric
  metricValue Float
  notes       String?
  recordedBy  String
  recorder    User          @relation(fields: [recordedBy], references: [id])
  observedAt  DateTime
  createdAt   DateTime      @default(now())

  @@index([candidateId])
  @@index([metricType])
}

enum OutcomeMetric {
  TRAINING_COMPLETION_DAYS
  RAMP_TIME_MONTHS
  NINETY_DAY_RETENTION
  SUPERVISOR_RATING
  QUALITY_SCORE
  SAFETY_INCIDENT
  TRAINING_TEST_SCORE
  PROMOTION
}

model ItemCalibration {
  id             String    @id @default(cuid())
  itemId         String
  construct      Construct
  version        Int
  difficulty     Float
  discrimination Float
  guessing       Float
  sampleSize     Int
  fitStatistic   Float?
  flagged        Boolean   @default(false)
  flagReason     String?
  calibratedAt   DateTime
  createdAt      DateTime  @default(now())

  @@unique([itemId, version])
  @@index([construct])
  @@index([flagged])
}

// ──────────────────────────────────────────────
// V2 CONVERSATIONAL ASSESSMENT
// ──────────────────────────────────────────────

model ConversationMessage {
  id              String                  @id @default(cuid())
  assessmentId    String
  assessment      Assessment              @relation(fields: [assessmentId], references: [id])
  role            ConvoMessageRole
  content         String
  act             AssessmentAct
  metadata        Json?                   // Beat number, scenario index, construct signals, etc.
  elementType     InteractionElementType?
  elementData     Json?                   // Options, correct answer, timer config, etc.
  candidateInput  String?                 // Candidate's structured response to an interactive element
  responseTimeMs  Int?
  sequenceOrder   Int
  createdAt       DateTime                @default(now())

  @@index([assessmentId, act])
  @@index([assessmentId, sequenceOrder])
}

model AssessmentState {
  id                String        @id @default(cuid())
  assessmentId      String        @unique
  assessment        Assessment    @relation(fields: [assessmentId], references: [id])
  currentAct        AssessmentAct @default(ACT_1)
  currentScenario   Int           @default(0)
  currentBeat       Int           @default(0)
  currentConstruct  String?
  currentPhase      Int?
  branchPath        Json?
  act2Progress      Json?
  act3Progress      Json?
  contentLibraryId  String?       // Snapshot: which content library version this assessment uses
  variantSelections Json?         // { scenarioId: variantIndex } random selection per scenario
  phase0Complete    Boolean       @default(false)
  isComplete        Boolean       @default(false)
  realtimeTokensIn  Int           @default(0)
  realtimeTokensOut Int           @default(0)
  act1CompletedAt   DateTime?
  act2CompletedAt   DateTime?
  act3CompletedAt   DateTime?
  updatedAt         DateTime      @updatedAt
  createdAt         DateTime      @default(now())
}

model AIEvaluationRun {
  id              String     @id @default(cuid())
  assessmentId    String
  assessment      Assessment @relation(fields: [assessmentId], references: [id])
  messageId       String
  construct       Construct
  runIndex        Int
  indicatorScores Json
  aggregateScore  Float
  modelId         String
  latencyMs       Int
  rawOutput       String
  createdAt       DateTime   @default(now())

  @@index([assessmentId, construct])
  @@index([messageId])
}
